---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE_NAME } from "@/lib/seo";
---

<BaseLayout title={`404 — ${SITE_NAME}`} noIndex={true}>
  <div class="max-w-[720px] mx-auto px-6 py-24 text-center">
    <p class="font-mono text-xs text-fg-subtle uppercase tracking-widest mb-4">404</p>
    <h1 class="font-serif text-title text-fg mb-4">Page not found</h1>
    <p class="text-fg-muted mb-10">
      That URL doesn't exist. Maybe the tip was renamed, or the link is stale.
    </p>
    <div class="flex items-center justify-center gap-4 flex-wrap">
      <a
        href="/"
        class="bg-accent text-white text-sm font-medium px-5 py-2.5 rounded-md hover:opacity-90 transition-opacity"
      >
        Go home
      </a>
      <a href="/laravel" class="text-sm text-fg-muted hover:text-fg transition-colors px-4 py-2.5">
        Browse tips →
      </a>
    </div>
  </div>
</BaseLayout>
